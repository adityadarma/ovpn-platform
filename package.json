{
  "name": "ovpn-platform",
  "version": "1.0.0",
  "private": true,
  "description": "OVPN — VPN Management Platform",
  "scripts": {
    "dev": "turbo run dev --filter=!@ovpn/agent",
    "agent:dev": "turbo run dev --filter=@ovpn/agent",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @ovpn/db migrate",
    "db:seed": "pnpm --filter @ovpn/db seed",
    "db:rollback": "pnpm --filter @ovpn/db rollback"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "prettier": "^3.5.3",
    "@types/node": "^22.13.10"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
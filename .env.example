# ============================================================
# VPN Manager — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- App ----
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ---- JWT ----
JWT_SECRET=change-me-super-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# ---- Node Registration Security ----
# Registration key for auto-registering VPN nodes
# Generate with: openssl rand -hex 32
NODE_REGISTRATION_KEY=

# ---- VPN Hooks Authentication ----
# Token for authenticating VPN hooks (vpn-connect, vpn-disconnect)
# Generate with: openssl rand -hex 32
VPN_TOKEN=

# ---- Database ----
# Options: postgres | mysql | sqlite
DATABASE_TYPE=sqlite

# PostgreSQL
DATABASE_URL=postgresql://vpn:vpn@localhost:5432/vpn

# MySQL / MariaDB
# DATABASE_URL=mysql://vpn:vpn@localhost:3306/vpn

# SQLite (default path, auto-resolved in code)
# DATABASE_SQLITE_PATH=/data/vpn.sqlite

# ---- Web (Development only) ----
# In production, Next.js static files are served by Fastify (same-origin).
# NEXT_PUBLIC_API_URL and WEB_URL are ONLY needed for local development.
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ============================================================
# OVPN Platform — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- API ----
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ---- JWT ----
JWT_SECRET=change-me-super-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# ---- Database ----
# Options: postgres | mysql | sqlite
DATABASE_TYPE=sqlite

# PostgreSQL
DATABASE_URL=postgresql://ovpn:ovpn@localhost:5432/ovpn

# MySQL / MariaDB
# DATABASE_URL=mysql://ovpn:ovpn@localhost:3306/ovpn

# SQLite (path to file)
# SQLite stored at: <project-root>/data/ovpn.sqlite (auto-resolved in code)
# Override: DATABASE_SQLITE_PATH=/custom/path/to/db.sqlite

# ---- Web UI ----
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_PORT=3000

# ---- Agent ----
AGENT_PORT=3002
AGENT_MANAGER_URL=http://localhost:3001
AGENT_NODE_ID=
AGENT_SECRET_TOKEN=change-me-agent-secret-token
AGENT_POLL_INTERVAL_MS=5000
AGENT_HEARTBEAT_INTERVAL_MS=30000

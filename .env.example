# ============================================================
# VPN Manager — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- API ----
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ---- JWT ----
JWT_SECRET=change-me-super-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# ---- Node Registration Security ----
# Registration key for auto-registering VPN nodes
# Generate with: openssl rand -hex 32
# Leave empty to require admin JWT token for registration
NODE_REGISTRATION_KEY=

# ---- VPN Hooks Authentication ----
# Token for authenticating VPN hooks (vpn-login, vpn-connect, vpn-disconnect)
# This token is used by OpenVPN hooks to authenticate with the API
# Generate with: openssl rand -hex 32
VPN_TOKEN=

# ---- Database ----
# Options: postgres | mysql | sqlite
DATABASE_TYPE=sqlite

# PostgreSQL
DATABASE_URL=postgresql://vpn:vpn@localhost:5432/vpn

# MySQL / MariaDB
# DATABASE_URL=mysql://vpn:vpn@localhost:3306/vpn

# SQLite (path to file)
# SQLite stored at: <project-root>/data/vpn.sqlite (auto-resolved in code)
# Override: DATABASE_SQLITE_PATH=/custom/path/to/db.sqlite

# ---- Web UI ----
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_PORT=3000

# ---- Agent ----
AGENT_PORT=3002
AGENT_MANAGER_URL=http://localhost:3001
AGENT_NODE_ID=
AGENT_SECRET_TOKEN=change-me-agent-secret-token
AGENT_POLL_INTERVAL_MS=5000
AGENT_HEARTBEAT_INTERVAL_MS=30000

{
  "name": "@ovpn/agent",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "ovpn-agent": "./dist/index.js",
    "openvpn-login": "./dist/bin/openvpn-login.js",
    "openvpn-connect": "./dist/bin/openvpn-connect.js",
    "openvpn-disconnect": "./dist/bin/openvpn-disconnect.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "login": "tsx src/bin/openvpn-login.ts",
    "connect": "tsx src/bin/openvpn-connect.ts",
    "disconnect": "tsx src/bin/openvpn-disconnect.ts"
  },
  "dependencies": {
    "@ovpn/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "commander": "^14.0.3",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.12.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
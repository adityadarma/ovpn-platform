# VPN Agent — Environment Configuration
# Copy this file to /opt/vpn-agent/.env on the VPN server

# ─── Manager Connection ───────────────────────────────────────────────
# URL of the VPN Manager API server
AGENT_MANAGER_URL=http://your-manager-server:3001

# Node ID: obtained after calling POST /api/v1/nodes/register
# Run: pnpm agent:register  to get this value
AGENT_NODE_ID=

# Secret token returned from /api/v1/nodes/register (store securely!)
AGENT_SECRET_TOKEN=

# ─── VPN Auth Token ───────────────────────────────────────────────────
# Shared secret between VPN scripts and the Manager API.
# Must match the VPN_TOKEN in apps/api .env.
VPN_TOKEN=

# ─── Agent Behaviour ──────────────────────────────────────────────────
AGENT_POLL_INTERVAL_MS=5000
AGENT_HEARTBEAT_INTERVAL_MS=30000

# ─── Firewall Mode ────────────────────────────────────────────────────
# Set to "true" if your server uses nftables instead of iptables
USE_NFTABLES=false
